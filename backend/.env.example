# Azure Blob Storage
AZURE_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
AZURE_BLOB_CONTAINER=hearsay

# Database
DB_PATH=/data/hearsay.duckdb

# Server
ASPNETCORE_URLS=http://+:5000
ALLOWED_ORIGINS=https://apps.kjsoft.dk,http://localhost:3000

# JWT Authentication (optional - for user accounts)
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_ISSUER=hearsay-api
JWT_AUDIENCE=hearsay-app
JWT_EXPIRATION_HOURS=168

# Stripe Payments (optional - for premium subscriptions)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
